# ALS-RAG Environment Configuration
# ==================================
# ALL KEYS ARE OPTIONAL - The system works without any API keys!

# PubMed/NCBI (Optional) - 3 req/s without key, 10 req/s with key
# PUBMED_API_KEY=

# Semantic Scholar (Optional)
# SEMANTIC_SCHOLAR_API_KEY=

# Contact Email (Optional but recommended for polite API identification)
# CONTACT_EMAIL=your.email@institution.edu

# OpenAI API Key (Required for LLM generation features only)
# OPENAI_API_KEY=
